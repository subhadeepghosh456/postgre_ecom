enum UserType {
  ADMIN
  USER
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String   
  addresses Address[] @relation("UserAddress")
  avatar    String?
  role      UserType  @default(USER)
  
  // Named relation added here to match the Product model
  products  Product[] @relation("AdminProducts")
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}